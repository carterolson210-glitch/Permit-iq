# Public — safe to expose to the browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe price/product IDs used by the client to start checkout sessions
VITE_STRIPE_PRICE_HOMEOWNER=price_xxx
VITE_STRIPE_PRICE_CONTRACTOR_MONTHLY=price_xxx
VITE_STRIPE_PRICE_CONTRACTOR_ANNUAL=price_xxx
VITE_STRIPE_PRICE_FIRM_MONTHLY=price_xxx
VITE_STRIPE_PRICE_FIRM_ANNUAL=price_xxx

# Server-only — configure in Supabase Edge Function secrets, NOT in Vite env.
# Never prefix these with VITE_ or they will leak to the browser bundle.
# ANTHROPIC_API_KEY=sk-ant-xxx
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# RESEND_API_KEY=re_xxx
