# Public — safe to expose to the browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Price IDs are NOT client env vars — the stripe-checkout edge function maps
# plan+billing to STRIPE_PRICE_* from its own secrets (see SETUP.md).

# Server-only — configure in Supabase Edge Function secrets, NOT in Vite env.
# Never prefix these with VITE_ or they will leak to the browser bundle.
# ANTHROPIC_API_KEY=sk-ant-xxx
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# RESEND_API_KEY=re_xxx
